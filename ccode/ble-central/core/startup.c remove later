extern uint8_t _estack[];
extern uint8_t _sidata[], _sdata[], _edata[];
extern uint8_t _iccmdata[], _sccmdata[], _eccmdata[];

extern uint8_t _sbss[], _ebss[];
extern uint8_t fast_start[], fast_end[], fast_init[];

void main( void );
const uint32_t vectors[] __attribute__ ((section (".vectors"))); 

void _start( void ) __attribute__ ((section(".boot")));

void out( int x)
{
    while( !(USART1->SR & USART_SR_TXE) )
        continue;
    USART1->DR = x;
}

void outhex( int x )
{
    static char buf[16];

    sprintf( buf, "%08x\r\n", x );
    for( int i = 0; buf[i]; i++ )
        out( buf[i] );
}

void _start( void )
{
    __asm__( "   ldr r1, =_estack\n   mov sp, r1\n" );
    // enable FPU access (full access to copro 10 and 11)
    SCB->CPACR |= (3 << 20) | (3 << 22);
    SCB->VTOR = (unsigned long) vectors;
    memcpy( _sccmdata, _iccmdata, _eccmdata - _sccmdata );
    memcpy( fast_start, fast_init, fast_end - fast_start );
    memcpy( _sdata, _sidata, _edata - _sdata );
    memset( _sbss, 0, _ebss - _sbss );
    main( );
}

